# 腾讯云SMS配置（用于真实短信发送）
# 前往 https://console.cloud.tencent.com/smsv2 获取以下信息

# SecretId（在访问管理 -> API密钥管理中获取）
TENCENT_SMS_SECRET_ID=your_secret_id

# SecretKey（在访问管理 -> API密钥管理中获取）
TENCENT_SMS_SECRET_KEY=your_secret_key

# 短信应用 SDKAppId（在短信应用管理中获取）
TENCENT_SMS_SDK_APP_ID=1400000000

# 签名名称（在签名管理中获取，需要已审核通过）
TENCENT_SMS_SIGN_NAME=味享

# 模板ID（在正文模板管理中获取，需要已审核通过）
# 模板内容示例：您的验证码是{1}，5分钟内有效
TENCENT_SMS_TEMPLATE_ID=000000

# JWT密钥
JWT_SECRET=your-super-secret-key-change-in-production
